{
  "name": "school-erp",
  "version": "1.0.0",
  "description": "A school ERP system built with React and Express.",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "client": "npm start --prefix client",
    "server": "node server/app.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "postinstall": "npm install --prefix client && npm run build --prefix client",
    "install-all": "npm install && npm install --prefix client",
    "build": "npm run build --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.17.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.10.9"
  },
  "devDependencies": {
    "concurrently": "^5.3.0"
  },
  "author": "",
  "license": "ISC"
}
