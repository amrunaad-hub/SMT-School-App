{
  "name": "school-erp",
  "version": "1.0.0",
  "description": "A school ERP system built with React and Express.",
  "main": "server/app.js",
  "scripts": {
    "start": "node server/app.js",
    "client": "npm start --prefix client",
    "server": "node server/app.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "postinstall": "npm install --prefix client && npm run build --prefix client",
    "install-all": "npm install && npm install --prefix client",
    "build": "npm run build --prefix client",
    "tools": "node tools/server.js",
    "test": "npm run test:server && npm run test:client",
    "test:server": "jest server/tests --forceExit --passWithNoTests",
    "test:client": "cross-env CI=true npm test --prefix client -- --watchAll=false",
    "test:e2e": "npx playwright test",
    "test:coverage": "jest server/tests --coverage --forceExit --passWithNoTests",
    "lint": "eslint server/ client/src/ --ext .js,.jsx --max-warnings 0",
    "lint:fix": "eslint server/ client/src/ --ext .js,.jsx --fix",
    "format": "prettier --write \"server/**/*.js\" \"client/src/**/*.{js,jsx}\"",
    "format:check": "prettier --check \"server/**/*.js\" \"client/src/**/*.{js,jsx}\"",
    "seed": "node server/utils/seedUsers.js",
    "build:analyze": "cross-env GENERATE_SOURCEMAP=true npm run build --prefix client"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.17.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^5.10.9"
  },
  "devDependencies": {
    "concurrently": "^5.3.0"
  },
  "author": "",
  "license": "ISC"
}
